# =============================================================================
# API Fetch Manager — .env.example
# Mọi biến BẮT BUỘC prefix API_FETCH_MANAGER_ ([SYS] 7.2, [REQ] 4).
# Copy file này thành `.env` và điền giá trị.
# Mỗi biến gồm 5 mục: (1) diễn giải · (2) tác dụng · (3) cách cấu hình ·
#                      (4) cách lấy giá trị · (5) ràng buộc bắt buộc.
# =============================================================================

# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_PORT
# (1) Cổng HTTP server lắng nghe.
# (2) Quyết định app phục vụ API + UI ở cổng nào.
# (3) Đặt số nguyên > 0. Docker map cổng này ra host.
# (4) Tự chọn (mặc định 8080). Trên runner nên khớp cổng được mở.
# (5) Bắt buộc là số nguyên dương. Mặc định 8080 nếu bỏ trống.
API_FETCH_MANAGER_PORT=8080

# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_LOG_LEVEL
# (1) Mức log của server.
# (2) Điều chỉnh độ chi tiết log (debug khi cần trace).
# (3) Một trong: fatal | error | warn | info | debug | trace.
# (4) Tự chọn theo môi trường (prod nên info).
# (5) Không bắt buộc. Mặc định info.
API_FETCH_MANAGER_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_STORAGE_MODE
# (1) Chế độ lưu trữ dữ liệu.
# (2) Chọn backend lưu 5 "RTDB" logic (keys/history/logs/issues/variables).
# (3) Một trong:
#       memory   — RAM, mất khi restart (dùng test/demo nhanh)
#       file     — JSON trên đĩa (giữ qua restart, phù hợp self-host nhỏ)
#       firebase — Google Realtime Database thật (production đúng SPEC)
# (4) Tự chọn. Production đúng SPEC dùng firebase.
# (5) Không bắt buộc. Mặc định memory. Nếu = firebase thì các biến RTDB_* + FIREBASE_SA trở thành bắt buộc.
API_FETCH_MANAGER_STORAGE_MODE=file

# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_DATA_DIR
# (1) Thư mục lưu file JSON khi STORAGE_MODE=file.
# (2) Nơi ghi rtdb-*.json.
# (3) Đường dẫn tuyệt đối/ tương đối. Trong Docker nên là /data (mount volume).
# (4) Tự chọn.
# (5) Chỉ dùng khi STORAGE_MODE=file. Mặc định .data.
API_FETCH_MANAGER_DATA_DIR=/data

# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_ENCRYPTION_KEY
# (1) Khóa mã hóa credential at-rest (AES-256-GCM).
# (2) Dùng để encrypt/decrypt mọi credential; đổi khóa = mất khả năng giải mã dữ liệu cũ.
# (3) Chuỗi base64 của đúng 32 byte ngẫu nhiên.
# (4) Sinh bằng: `openssl rand -base64 32`  hoặc
#                `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
# (5) BẮT BUỘC ở production/firebase. PHẢI giải mã ra đúng 32 byte, nếu không app dừng.
API_FETCH_MANAGER_ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_ADMIN_TOKEN
# (1) Token quản trị dùng ở header `Authorization: Bearer <token>`.
# (2) Bảo vệ mọi endpoint /api ngoài /api/health, đặc biệt reveal/export plaintext credential.
# (3) Đặt chuỗi ngẫu nhiên dài (khuyến nghị >= 32 byte entropy); FE/API client phải gửi Bearer token tương ứng.
# (4) Sinh bằng: `openssl rand -base64 32`.
# (5) Bắt buộc khi STORAGE_MODE=file hoặc firebase; khuyến nghị bật ở mọi môi trường có dữ liệu thật.
API_FETCH_MANAGER_ADMIN_TOKEN=


# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_HTTP_TIMEOUT_MS
# (1) Timeout cho mỗi HTTP request outbound (executor + Firebase REST).
# (2) Ngăn flow/API treo vô hạn khi endpoint bên ngoài không phản hồi.
# (3) Đặt số milliseconds dương.
# (4) Tự chọn theo SLA API đích; mặc định 15000.
# (5) Không bắt buộc. Nếu đặt thì phải là số dương.
API_FETCH_MANAGER_HTTP_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_HTTP_RETRIES
# (1) Số lần retry sau lần gọi đầu cho lỗi mạng/timeout/HTTP 429/5xx.
# (2) Tăng độ bền flow khi API đích lỗi tạm thời.
# (3) Đặt số nguyên >= 0.
# (4) Tự chọn theo idempotency API đích; mặc định 2.
# (5) Không bắt buộc. Nếu flow có side-effect không idempotent, cân nhắc đặt 0.
API_FETCH_MANAGER_HTTP_RETRIES=2

# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_HTTP_MAX_RESPONSE_BYTES
# (1) Giới hạn kích thước response text đọc vào memory cho executor.
# (2) Tránh response quá lớn làm tốn RAM/log/history.
# (3) Đặt số byte dương.
# (4) Tự chọn theo payload API đích; mặc định 1048576 (1 MiB).
# (5) Không bắt buộc. Nếu đặt thì phải là số dương.
API_FETCH_MANAGER_HTTP_MAX_RESPONSE_BYTES=1048576

# =============================================================================
# CHỈ CẦN KHI STORAGE_MODE=firebase
# =============================================================================

# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_FIREBASE_SA
# (1) Service Account JSON của Firebase (đã encode base64).
# (2) Cấp quyền Admin SDK truy cập các RTDB.
# (3) Tải service account JSON từ Firebase Console → base64 hóa toàn bộ file.
# (4) Firebase Console → Project Settings → Service accounts → Generate new private key;
#     rồi: `base64 -w0 serviceAccount.json`.
# (5) Bắt buộc khi firebase. Giữ bí mật tuyệt đối, KHÔNG commit.
API_FETCH_MANAGER_FIREBASE_SA=

# -----------------------------------------------------------------------------
# API_FETCH_MANAGER_RTDB_KEYS_URL / HISTORY / LOGS / ISSUES / VARIABLES
# (1) URL của từng Realtime Database độc lập (5 DB tách biệt).
# (2) Mỗi nghiệp vụ dùng 1 DB riêng để tối ưu & cô lập.
# (3) Dạng https://<db-name>.firebaseio.com (hoặc *.<region>.firebasedatabase.app).
# (4) Firebase Console → Realtime Database → tạo 5 instance, copy URL từng cái.
#     Nhớ nạp rules từ docker/database.rules.json để có .indexOn đúng.
# (5) Cả 5 bắt buộc khi firebase.
API_FETCH_MANAGER_RTDB_KEYS_URL=
API_FETCH_MANAGER_RTDB_HISTORY_URL=
API_FETCH_MANAGER_RTDB_LOGS_URL=
API_FETCH_MANAGER_RTDB_ISSUES_URL=
API_FETCH_MANAGER_RTDB_VARIABLES_URL=
